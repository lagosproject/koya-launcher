<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/widget_item_bg"
    android:clickable="true"
    android:focusable="true">

    <!-- Header info: App Icon, App Name, Widget Size -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivAppIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/ivAppIcon"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:textColor="@color/text_dim"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvWidgetSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light" />

    </RelativeLayout>

    <!-- Widget Label -->
    <TextView
        android:id="@+id/tvWidgetLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="sans-serif-light" />

    <!-- Widget Preview Container & Preview Image -->
    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#1Fffffff"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivWidgetPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:maxHeight="180dp"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvNoPreviewPlaceholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#80ffffff"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light"
            android:text="@string/no_preview_available"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
