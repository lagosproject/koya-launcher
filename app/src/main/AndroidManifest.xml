<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.BIND_APPWIDGET" tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.APPWIDGET_CONFIGURE"/>
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission"/>
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM"/>
    <uses-permission android:name="android.permission.READ_CALENDAR"/>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.Koya"
        android:supportsRtl="true">

        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:screenOrientation="portrait"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode"
            android:windowSoftInputMode="adjustPan">
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.HOME"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".AppDrawerActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Koya.Translucent"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".AppPickerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Koya.Translucent"/>

        <activity
            android:name=".WidgetPickerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Koya.Translucent"/>

        <activity android:name=".SettingsActivity" 
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Koya" />

    </application>

</manifest>
